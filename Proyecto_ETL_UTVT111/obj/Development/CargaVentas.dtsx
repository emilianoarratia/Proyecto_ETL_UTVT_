          SQLTask:SqlStatementSource="INSERT INTO dbo.LogProceso (NombrePaquete, FechaInicio, Estatus, Mensaje)&#xA;VALUES ('CargaVentas.dtsx', GETDATE(), 'EN_PROCESO', 'Inicio de ejecucion')" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
