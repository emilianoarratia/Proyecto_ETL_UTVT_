      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{FCEE38BE-BE83-40BD-BB30-F944945A131D}"
          SQLTask:SqlStatementSource="UPDATE dbo.LogProceso&#xA;SET FechaFin         = GETDATE(),&#xA;    DuracionSegundos = DATEDIFF(SECOND, FechaInicio, GETDATE()),&#xA;    Estatus          = 'EXITOSO',&#xA;    Mensaje          = 'Proceso completado correctamente'&#xA;WHERE IdProceso = (SELECT MAX(IdProceso) FROM dbo.LogProceso)" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
