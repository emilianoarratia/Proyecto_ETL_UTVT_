                          description="Specifies the expression. This expression version uses lineage identifiers instead of column names."
                          name="Expression">#{Package\SEQ_Productos\CargarProductos\SRC_Productos.Outputs[Flat File Source Output].Columns[Activo]} == "1" &amp;&amp; (DT_NUMERIC,10,2)#{Package\SEQ_Productos\CargarProductos\SRC_Productos.Outputs[Flat File Source Output].Columns[Precio]} &gt; 0 &amp;&amp; (DT_NUMERIC,10,2)#{Package\SEQ_Productos\CargarProductos\SRC_Productos.Outputs[Flat File Source Output].Columns[Costo]} &gt; 0 &amp;&amp; (#{Package\SEQ_Productos\CargarProductos\DRV_LimpiezaProductos.Outputs[Derived Column Output].Columns[Categoria_Limpia]} == "COMPUTO" || #{Package\SEQ_Productos\CargarProductos\DRV_LimpiezaProductos.Outputs[Derived Column Output].Columns[Categoria_Limpia]} == "ACCESORIOS" || #{Package\SEQ_Productos\CargarProductos\DRV_LimpiezaProductos.Outputs[Derived Column Output].Columns[Categoria_Limpia]} == "MUEBLES" || #{Package\SEQ_Productos\CargarProductos\DRV_LimpiezaProductos.Outputs[Derived Column Output].Columns[Categoria_Limpia]} == "REDES" || #{Package\SEQ_Productos\CargarProductos\DRV_LimpiezaProductos.Outputs[Derived Column Output].Columns[Categoria_Limpia]} == "ALMACENAMIENTO" || #{Package\SEQ_Productos\CargarProductos\DRV_LimpiezaProductos.Outputs[Derived Column Output].Columns[Categoria_Limpia]} == "INFRAESTRUCTURA")</property>
